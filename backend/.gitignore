# Dependencies
/node_modules
/jspm_packages

# TypeScript cache/declaration files
/typings

# Compiled JavaScript and source maps (adjust 'dist' and 'build' to match your actual output directory from tsconfig.json)
/dist
/build
/*.js.map
/*.d.ts
!src/**/*.d.ts # Except for declaration files in src/ which might be desired

# Optional npm cache files
.npm
.eslintcache

# Optional REPL history
.node_repl_history

# Environment variables
.env
.env.*
!.env.example # Keep an example file for reference

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# OS and Editor files
.DS_Store # macOS
Thumbs.db # Windows
.vscode/ # VS Code directory (optional, remove if you want to share settings)

# NYC test coverage
coverage
.nyc_output

# Output of 'npm pack'
*.tgz

# Next.js build output
.next

# Nuxt.js build output
.nuxt

# VuePress build output
.vuepress/dist

# Serverless directories
.serverless
